# LINE Developers コンソール > チャネル基本設定 > チャネルシークレット
LINE_CHANNEL_SECRET=

# LINE Developers コンソール > Messaging API設定 > チャネルアクセストークン(長期)
LINE_CHANNEL_ACCESS_TOKEN=

# Google AI Studio (https://aistudio.google.com/apikey) で無料発行
GEMINI_API_KEY=

# 利用を許可する LINE user_id をカンマ区切りで指定(空なら誰でも利用可)
# 調べ方: 一度Botに話しかけ、Renderのログに出る "user_id: U..." を確認する
ALLOWED_USER_IDS=
